{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fixed-screen",
  "version": "1.0.0",
  "identifier": "com.fixed-screen.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "fixed-screen",
        "width": 350,
        "height": 175,
        "resizable": false,
        "visible": true,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/fixed_32x32.png",
      "icons/fixed_128x128.png",
      "icons/fixed_128x128.png",
      "icons/fixed_32x32.icns",
      "icons/fixed_32x32.ico"
    ]
  }
}
